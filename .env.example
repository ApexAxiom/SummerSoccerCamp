# Local server
PORT=4242
APP_URL=http://localhost:4242

# Stripe test mode keys and price IDs
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_GROUP_PRICE_ID=price_replace_group_training
STRIPE_PRIVATE_PRICE_ID=price_replace_private_training

# Optional labels shown on the public site. Keep Stripe as the source of truth.
GROUP_DISPLAY_PRICE=
PRIVATE_DISPLAY_PRICE=

# Coach/admin view
ADMIN_TOKEN=replace_with_a_long_random_value

# Public contact info shown on the site and in confirmation emails (optional)
CONTACT_EMAIL=
CONTACT_PHONE=

# Email confirmations (optional). When RESEND_API_KEY and MAIL_FROM are set,
# parents get a signup confirmation and the coach gets a new-signup alert.
# Without them the app still records payments and just logs the email instead.
RESEND_API_KEY=
MAIL_FROM=
# Where coach alerts go. Defaults to CONTACT_EMAIL when blank.
COACH_EMAIL=
